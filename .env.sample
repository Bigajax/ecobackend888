# Analytics pipeline
ECO_ANALYTICS_ENABLED=true
ECO_BUDGET_ADITIVO_TOKENS=800
BANDIT_LAMBDA=0.01

# Enable GPT-5.0 for emotional intensity detection (robust emotion analysis)
ECO_ENABLE_GPT5_INTENSITY=true

# Resumo do perfil emocional gerado por IA (Claude). Desligue com =false para usar o template fixo.
ECO_PERFIL_IA_ENABLED=true

# Meta Conversions API (CAPI) — disparado no webhook do Mercado Pago para
# StartTrial (trial autorizado) e Subscribe (1ª cobrança real). DEVE ser o MESMO
# ID do fbq('init') no index.html do frontend (1452404496069451), senão a
# deduplicação por event_id quebra e a conversão duplica/fica órfã.
META_PIXEL_ID=1452404496069451
META_CAPI_TOKEN=your-meta-capi-access-token
# Opcional: código de teste do Events Manager (Test Events) para validar no painel.
META_TEST_EVENT_CODE=

# Mercado Pago — pagamentos
MP_ACCESS_TOKEN=your-mp-access-token
MP_WEBHOOK_SECRET=your-mp-webhook-secret
# Protocolo do Sono — checkout único via Pix (funil /sono/experiencia). Preço em BRL.
# Mudar aqui + reiniciar o serviço troca o valor SEM redeploy de código (default 37).
SONO_PIX_PRICE_BRL=37

# Mixpanel (server-side) — MESMO projeto/token do frontend (host EU: api-eu.mixpanel.com).
# SEM isto os eventos server-side do webhook ("Funil Protocolo · Pagamento confirmado"
# e "Unlock concedido") viram no-op silencioso — foi uma das causas de "nunca subiu".
# Configurar também no Render (env do serviço), não só aqui.
MIXPANEL_TOKEN=your-mixpanel-project-token
