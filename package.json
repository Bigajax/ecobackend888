{
  "scripts": {
    "clean": "rm -rf dist server/dist node_modules",
    "build": "tsc --noEmit -p tsconfig.json",
    "test": "npm run test:node && npm run test:jest",
    "test:node": "cross-env NODE_OPTIONS=\"-r ts-node/register -r ./server/tests/setupEnv.js\" TS_NODE_TRANSPILE_ONLY=1 node --test --test-force-exit --test-timeout=30000 \"server/tests/**/*.test.ts\" \"server/tests/**/*.test.js\"",
    "test:jest": "jest --config jest.config.ts",
    "test:golden": "cross-env NODE_OPTIONS=\"-r ts-node/register\" TS_NODE_TRANSPILE_ONLY=1 node --test server/tests/promptContext/promptContract.golden.test.ts",
    "eval:run": "ts-node --transpile-only server/evals/index.ts",
    "test:contract": "jest --config server/jest.contract.config.ts",
    "test:supabase": "ts-node server/scripts/testSupabasePersistence.ts",
    "test:meditation-feedback": "ts-node server/scripts/testMeditationFeedback.ts",
    "modules:inventory": "ts-node server/scripts/modulesInventory.ts",
    "prompt:dump": "ts-node --transpile-only server/scripts/dumpPrompt.ts",
    "smoke:feedback": "bash server/scripts/smokeFeedback.sh",
    "modules:dump": "ts-node --transpile-only server/scripts/modulesInventory.ts --dump-modules",
    "shadow:smoke": "ts-node --transpile-only server/scripts/shadowSmoke.ts",
    "pilot:smoke": "ts-node server/scripts/pilotSmoke.ts",
    "pilot:health": "ts-node --transpile-only server/scripts/pilotHealth.ts",
    "bandit:cache": "ts-node --transpile-only server/scripts/banditPosteriorCache.ts",
    "cron:self-test": "ts-node --transpile-only server/scripts/cronSelfTest.ts",
    "diagnosis:subscription": "ts-node --transpile-only server/scripts/diagnosisSubscription.ts",
    "test:subscription-payments": "ts-node --transpile-only server/scripts/testSubscriptionPayments.ts",
    "migration:subscription": "ts-node --transpile-only server/scripts/applySubscriptionMigration.ts"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.5.2",
    "cross-env": "^10.1.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.10",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.58.0",
    "axios": "^1.12.2",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "mercadopago": "^2.12.0",
    "natural": "^8.1.0",
    "resend": "^6.9.3",
    "zod": "^4.1.11"
  }
}
